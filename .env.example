###############################################################################
#                                ↓ REQUIRED ↓                                 #
###############################################################################

# Network to run the node on ("worldchain-mainnet" or "worldchain-sepolia")
NETWORK_NAME=worldchain-mainnet

# Execution client to use ("geth" or "reth"), defaults to "reth"
COMPOSE_PROFILES=reth

# Type of pruning to use -- "full" is recommended for most users
# Reth supports "full" (pruned), "minimal" (maximally pruned, lowest disk usage), and any other value is completely unpruned (default)
# Geth supports "full" (default, pruned) and "archive" (unpruned)
NODE_TYPE=archive

# L1 node that op-node will get chain data from
L1_RPC_ENDPOINT=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# L1 beacon endpoint, also needed for op-node
L1_BEACON_RPC_ENDPOINT=https://xxx-xxx-xxx.quiknode.pro/xxxxxxxxxx

# Type of RPC that op-node is connected to, see README
L1_RPC_TYPE=alchemy

###############################################################################
#                                ↓ OPTIONAL ↓                                 #
###############################################################################

# Set to "true" to enable flashblocks when using op-reth (no effect on op-geth)
# Not recommended to enable for World Chain Mainnet
FLASHBLOCKS_ENABLED=false

# Set to "false" to skip downloading snapshots for op-reth
# Syncing from scratch is not recommended, it will take over a week
DOWNLOAD_SNAPSHOT=true

# Set to "full" to force op-geth to use --syncmode=full
# Defaults to "snap" for full node, "full" for archive node
GETH_SYNCMODE=

# Set to "hash" to force op-geth to use --state.scheme=hash
# Use "hash" state scheme if eth_getProof support is required
# This value is overridden to match existing storage, changing this value requires a full re-sync
GETH_STATE_SCHEME=path

# Exposed server ports (must be unique)
# See docker-compose.yml for default values
PORT__GRAFANA=
PORT__EXECUTION_HTTP=
PORT__EXECUTION_WS=
PORT__EXECUTION_P2P=
PORT__CONSENSUS_P2P=
PORT__CONSENSUS_HTTP=
